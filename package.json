{
  "name": "ungdungmoi",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"nodemon server/index.js\"",
    "dev:client": "vite",
    "dev:server": "nodemon server/index.js",
    "build": "npx prisma generate --schema=server/prisma/schema.prisma && vite build && npx prisma migrate deploy --schema=server/prisma/schema.prisma && node server/prisma/seed.js",
    "start": "node server/index.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "db:migrate": "npx prisma migrate dev --schema=server/prisma/schema.prisma",
    "db:seed": "node server/prisma/seed.js",
    "db:studio": "npx prisma studio --schema=server/prisma/schema.prisma"
  },
  "prisma": {
    "schema": "server/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.577.0",
    "multer": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.2",
    "vite": "^8.0.0"
  }
}
