generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String
  role          String   @default("user")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  age           Int?
  gender        String?
  location      String?
  bio           String?
  avatar        String?
  interests     String?

  walletBalance Int      @default(0)

  swipesSent     Swipe[]  @relation("SwipeSender")
  swipesReceived Swipe[]  @relation("SwipeTarget")

  datePostsCreated DatePost[] @relation("DatePostAuthor")
  applicationsSent DateApplication[] @relation("Applicant")
  messagesSent     Message[] @relation("MessageSender")
  conversations    ConversationMember[]
  transactions     Transaction[]
  images           UserImage[]

  blocksSent       Block[]  @relation("BlocksSent")
  blocksReceived   Block[]  @relation("BlocksReceived")
  reportsSent      Report[] @relation("ReportsSent")
  reportsReceived  Report[] @relation("ReportsReceived")
}

model UserImage {
  id     String @id @default(uuid())
  userId String
  url    String
  order  Int    @default(0)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Swipe {
  id        String   @id @default(uuid())
  senderId  String
  targetId  String
  action    String
  createdAt DateTime @default(now())

  sender User @relation("SwipeSender", fields: [senderId], references: [id], onDelete: Cascade)
  target User @relation("SwipeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([senderId, targetId])
}

model Match {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())

  @@unique([user1Id, user2Id])
}

model DatePost {
  id          String   @id @default(uuid())
  authorId    String
  category    String
  title       String
  description String?
  icon        String   @default("coffee")
  time        String?
  place       String?
  price       Int?
  maxApply    Int      @default(1)
  status      String   @default("open")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author       User              @relation("DatePostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  applications DateApplication[]
}

model DateApplication {
  id          String   @id @default(uuid())
  postId      String
  applicantId String
  message     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  post      DatePost @relation(fields: [postId], references: [id], onDelete: Cascade)
  applicant User     @relation("Applicant", fields: [applicantId], references: [id], onDelete: Cascade)

  @@unique([postId, applicantId])
}

model Conversation {
  id         String   @id @default(uuid())
  type       String   @default("match")
  datePostId String?
  createdAt  DateTime @default(now())

  members  ConversationMember[]
  messages Message[]
}

model ConversationMember {
  id             String @id @default(uuid())
  conversationId String
  userId         String

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  text           String
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
}

model Transaction {
  id            String   @id @default(uuid())
  userId        String
  type          String
  amount        Int
  description   String?
  relatedPostId String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  blocker   User     @relation("BlocksSent", fields: [blockerId], references: [id])
  blocked   User     @relation("BlocksReceived", fields: [blockedId], references: [id])
  createdAt DateTime @default(now())
  @@unique([blockerId, blockedId])
}

model Report {
  id         String   @id @default(uuid())
  reporterId String
  reportedId String
  reason     String
  details    String?
  status     String   @default("pending")
  reporter   User     @relation("ReportsSent", fields: [reporterId], references: [id])
  reported   User     @relation("ReportsReceived", fields: [reportedId], references: [id])
  createdAt  DateTime @default(now())
}
